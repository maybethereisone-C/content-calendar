# ─────────────────────────────────────────────────────────────────
# Required at boot — server refuses to start when any are missing
# (per OPS-04). Validation lives in lib/env.ts (plan 02).
# ─────────────────────────────────────────────────────────────────

# Supabase — created in Supabase Dashboard during the headed deploy session.
# NEW key naming per references/supabase.md: sb_publishable_xxx / sb_secret_xxx.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=  # NEVER prefix with NEXT_PUBLIC_; server-only

# Buffer — Phase 1 only validates the key is present at boot (no API calls).
BUFFER_API_KEY=

# Telegram — Phase 1 only validates the token + chat ID are present.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# Public base URL of this deployment.
DASHBOARD_BASE_URL=https://dashboard.omnicai.online

# ─────────────────────────────────────────────────────────────────
# Optional — defaults to 'mock' in dev; production REFUSES 'mock' (per OPS-05).
# Plan 02 enforces: NODE_ENV=production AND (BUFFER_CLIENT=mock OR
# TELEGRAM_CLIENT=mock) -> process.exit(1) with stderr message
# "mock client refused in production".
# ─────────────────────────────────────────────────────────────────
BUFFER_CLIENT=mock      # mock | real — leave 'mock' in dev
TELEGRAM_CLIENT=mock    # mock | real — leave 'mock' in dev
NODE_ENV=development
LOG_LEVEL=info          # silent | error | warn | info | debug | trace

# ─────────────────────────────────────────────────────────────────
# Test-only — used by playwright/vitest with axe-core (REQ 24).
# Generate via: node scripts/generate-token.mjs
# ─────────────────────────────────────────────────────────────────
TEST_TOKEN=
